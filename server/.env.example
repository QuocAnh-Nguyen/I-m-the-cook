# ChefOne Server Environment Variables
# Copy this file to server/.env and fill in your values.

# ─── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────
# Local dev (PostgreSQL):
#   DATABASE_URL=postgresql://chefone:chefone_dev@localhost:5432/chefone_db
#
# Supabase (recommended for free cloud deployment):
#   1. Go to https://supabase.com → New Project
#   2. Copy the "Session pooler" connection string from Project Settings → Database
#   3. Replace [YOUR-PASSWORD] with the password you set:
#      DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Render (automatic PostgreSQL on Render):
#   DATABASE_URL is auto-injected — no manual config needed
DATABASE_URL=postgresql://chefone:chefone_dev@localhost:5432/chefone_db

# ─── JWT Authentication ──────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-your-own-secret-min-32-chars
JWT_EXPIRES_IN=24h

# ─── Frontend (CORS) ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Local dev:  http://localhost:3000
# Production: https://your-app-name.vercel.app
# Both:       http://localhost:3000,https://your-app-name.vercel.app
FRONTEND_URL=http://localhost:3000

# ─── File Uploads ────────────────────────────────────────────────────
# Note: Cloud platforms (Render, Railway) have ephemeral filesystems.
# Uploaded images WILL be lost on restart. For production, use a CDN
# or object storage (S3, Cloudflare R2) instead of disk storage.
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ─── Google Gemini AI ────────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/app/apikey
# The free tier supports ~1,500 requests/day — sufficient for a demo.
# WARNING: Set a usage cap at https://console.cloud.google.com/apis
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# ─── Optional: Rate Limiting ─────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100