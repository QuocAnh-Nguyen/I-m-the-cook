# ChefOne Server Environment Variables (example)

# Server
PORT=5000
NODE_ENV=development

# Database
# SQLite (local dev): file:./dev.db
# PostgreSQL (production): postgresql://chefone:chefone_dev@localhost:5432/chefone_db
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=replace-with-your-own-secret-min-32-chars
JWT_EXPIRES_IN=24h

# Frontend
FRONTEND_URL=http://localhost:3000

# File uploads
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads