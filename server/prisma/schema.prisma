// Prisma schema for ChefOne application
// Supports both SQLite (local dev) and PostgreSQL (production/deployment).
// Set DATABASE_URL accordingly in your .env file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ─────────────────────────────────────────────────────────

enum Difficulty {
  Easy
  Medium
  Hard
}

enum RecipeSource {
  MANUAL
  AI_GENERATED
  IMPORTED
}

enum GenerationStatus {
  GENERATED
  SAVED
  DISCARDED
}

enum PantryCategory {
  Proteins
  Vegetables
  Fruits
  Dairy
  Grains
  OilsAndCondiments
  Spices
  Other

  @@map("pantry_category")
}

enum DayOfWeek {
  Mon
  Tue
  Wed
  Thu
  Fri
  Sat
  Sun

  @@map("day_of_week")
}

enum MealType {
  Breakfast
  Lunch
  Dinner
  Snack

  @@map("meal_type")
}

enum ShoppingCategory {
  Produce
  Dairy
  Proteins
  Pantry
  Other

  @@map("shopping_category")
}

// ─── AUTH ─────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(uuid())
  email               String   @unique
  passwordHash        String
  name                String
  avatarUrl           String?
  calorieGoal         Int      @default(2000)
  proteinGoal         Int      @default(150)
  carbsGoal           Int      @default(250)
  fatGoal             Int      @default(65)
  dietaryPreferences  Json     @default("[]")
  cuisinePreferences  Json     @default("[]")
  allergies           Json     @default("[]")
  familySize          Int      @default(2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  recipes           Recipe[]
  pantryItems       PantryItem[]
  mealSlots         MealSlot[]
  calorieEntries    CalorieEntry[]
  shoppingItems     ShoppingItem[]
  generationHistory GenerationHistory[]

  @@map("users")
}

// ─── RECIPES ──────────────────────────────────────────────────────

model Recipe {
  id          String       @id @default(uuid())
  userId      String
  name        String
  prepTime    String
  cookTime    String
  servings    Int
  difficulty  Difficulty   @default(Easy)
  calories    Int
  protein     Int
  carbs       Int
  fat         Int
  fiber       Int          @default(0)
  tags        String[]
  ingredients Json
  steps       String[]
  notes       String?
  source      RecipeSource @default(MANUAL)
  isFavorite  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealSlotDishes MealSlotDish[]

  @@index([userId])
  @@index([userId, createdAt])
  @@map("recipes")
}

// ─── GENERATION HISTORY ───────────────────────────────────────────

model GenerationHistory {
  id            String            @id @default(uuid())
  userId        String
  prompt        String
  imageUrl      String?
  filters       Json?
  resultName    String
  resultData    Json
  status        GenerationStatus  @default(GENERATED)
  savedRecipeId String?
  createdAt     DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("generation_history")
}

// ─── PANTRY ───────────────────────────────────────────────────────

model PantryItem {
  id        String         @id @default(uuid())
  userId    String
  name      String
  category  PantryCategory
  quantity  Float
  unit      String
  expiry    DateTime
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
  @@index([userId, expiry])
  @@map("pantry_items")
}

// ─── MEAL PLANNER ─────────────────────────────────────────────────

model MealSlot {
  id         String    @id @default(uuid())
  userId     String
  weekStart  DateTime
  day        DayOfWeek
  mealType   MealType
  synced     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dishes MealSlotDish[]

  @@unique([userId, weekStart, day, mealType])
  @@index([userId, weekStart])
  @@map("meal_slots")
}

// ─── MEAL SLOT DISHES (Multi-dish support) ─────────────────────────

model MealSlotDish {
  id         String   @id @default(uuid())
  mealSlotId String
  recipeId   String?
  customName String?
  calories   Int      @default(0)
  protein    Int      @default(0)
  carbs      Int      @default(0)
  fat        Int      @default(0)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  mealSlot MealSlot @relation(fields: [mealSlotId], references: [id], onDelete: Cascade)
  recipe   Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([mealSlotId])
  @@map("meal_slot_dishes")
}

// ─── CALORIE TRACKER ──────────────────────────────────────────────

model CalorieEntry {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  mealType  MealType
  foodName  String
  quantity  Float
  unit      String
  calories  Int
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  fromPhoto Boolean  @default(false)
  imageUrl  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, date, mealType])
  @@map("calorie_entries")
}

// ─── SHOPPING LIST ────────────────────────────────────────────────

model ShoppingItem {
  id        String           @id @default(uuid())
  userId    String
  name      String
  category  ShoppingCategory
  quantity  String?
  checked   Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
  @@map("shopping_items")
}